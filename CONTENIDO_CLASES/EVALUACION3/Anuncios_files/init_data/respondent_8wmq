function ValidStartEndDate(startDate, endDate, canBeEqual) {
    try {
        if (Trim(startDate).length <= 0 &&
				Trim(endDate).length <= 0) {
            alert('Start and End date required!');
            return false;
        }
        else if (Trim(startDate).length <= 0 &&
				Trim(endDate).length > 0) {
            alert('Start date is required!');
            return false;
        }
        else if (Trim(startDate).length > 0 &&
				Trim(endDate).length <= 0) {
            alert('End date is required!');
            return false;
        }
        else if (Trim(startDate).length > 0 &&
				Trim(endDate).length > 0) {
            if (!isDate(Trim(startDate))) {
                alert('Start date is invalid!');
                return false;
            }
            if (!isDate(Trim(endDate))) {
                alert('End date is invalid!');
                return false;
            }
            var date1 = new Date(Trim(startDate));
            var date2 = new Date(Trim(endDate));

            if (date1 > date2) {
                alert('Start date must be less than End date!');
                return false;
            }
            else if (date1 == date2 && !canBeEqual) {
                alert('Start date must be less than End date!');
                return false;
            }
        }
    }
    catch (e) {
        return false;
    }

    return true;
}

