    var hasDecimalInterval =
      ($this.data("step") + "").indexOf(".") > -1 ||
      ($this.data("min") + "").indexOf(".") > -1 ||
      ($this.data("max") + "").indexOf(".") > -1;

    $this.find('input[type="text"]').bind("paste", function () {
      var tb = $(this);
      setTimeout(
        jQuery.proxy(function () {
          if (hasDecimalInterval) this.val(tb.val().replace(/[^0-9]/g, ""));
          else this.val(tb.val().replace(/[^0-9\.]/g, ""));
        }, $(this)),
        0,
      );
    });

    $this.find('input[type="text"]').on("keypress blur", function (event) {
      if (hasDecimalInterval) {
        //this.value = this.value.replace(/[^0-9\.]/g,'');
        $(this).val(
          $(this)
            .val()
            .replace(/[^0-9\.]/g, ""),
