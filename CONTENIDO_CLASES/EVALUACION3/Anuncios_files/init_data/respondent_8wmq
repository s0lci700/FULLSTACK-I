let CES_PAGE_LOAD_RUN = false;
// Set of scripts to run once the page loads
(() => {
  // protect against this script being included multiple times by mistake
  if (CES_PAGE_LOAD_RUN) {
    return;
  }
  CES_PAGE_LOAD_RUN = true;
  /**
   * Observe the DOM and invoke a callback if any of the provided nodes
   * (or an ancestor containing them) is removed from the document.
   * Automatically disconnects after the first trigger.
   *
   * @param {Node|Node[]} nodes Nodes to watch for removal.
   * @param {() => void} onRemoved Callback invoked once when any watched node is removed.
   * @returns {void}
   */
  const addRemovalListener = (nodes, onRemoved) => {
    const watchNodes = Array.isArray(nodes)
      ? nodes.filter(Boolean)
      : [nodes].filter(Boolean);
    if (watchNodes.length === 0) return;

    const observer = new MutationObserver((mutations) => {
      for (const m of mutations) {
        if (!m.removedNodes || m.removedNodes.length === 0) continue;

        for (const removed of m.removedNodes) {
          for (const target of watchNodes) {
            if (
              removed === target ||
              (removed.nodeType === 1 &&
                removed.contains &&
                removed.contains(target))
            ) {
              observer.disconnect();
              onRemoved();
              return;
            }
          }
        }
      }
    });

    observer.observe(document.body, { childList: true, subtree: true });
  };

  /**
   * For accessibility reasons, we need to add some sr-only text above every table that is sortable
   * If the table has an anchor tag as a child of one of its table headers, we consider it sortable
   *
   * To exclude your table from the ones we add notes to, add the class `no-sr-note` to the table.
   *
   * There's really no good reason this is written in javascript instead of being added to the gridview handlers,
   * except that it's much easier to write some javascript that runs everywhere than adding some c# that runs
   * for every grid view.
   *
   * @returns {void}
   */
  const addSortableSrOnlyText = () => {
    // Find all table elements
    const tables = document.querySelectorAll("table:not(.no-sr-note)");

    const addedNotes = [];

    tables.forEach((table) => {
      const anchors = Array.from(table.querySelectorAll("th a")).filter((a) => {
        const href = a.getAttribute("href") || "";
        return href.trim().toLowerCase().startsWith("javascript:");
      });

      if (anchors.length > 0) {
        if (!table.querySelector("caption")) {
          const srNote = document.createElement("caption");
          srNote.className = "sr-only sr-only-table-caption";
          srNote.textContent = "(column headers with links are sortable)";

          table.prepend(srNote);

          addedNotes.push(srNote);
        }
      }
    });

    addRemovalListener(addedNotes, () => {
      addSortableSrOnlyText();
    });
  };

  document.addEventListener("DOMContentLoaded", () => {
    addSortableSrOnlyText();
  });
})();
;
