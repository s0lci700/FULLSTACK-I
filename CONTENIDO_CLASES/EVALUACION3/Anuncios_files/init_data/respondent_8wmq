function setSliderValue(pnl, val) {
  var hasError = false;
  var newvaltoset = val;

  if (val.length === 0 || isNaN(parseFloat(val))) {
    hasError = true;
    newvaltoset = pnl.find("div.slider-obj").slider("option", "min");
  }
  if (val.length > 0 && !hasError) {
    var min = parseFloat(pnl.data("min"));
    var max = parseFloat(pnl.data("max"));
    var thisval = parseFloat(val);
    if (thisval < min) {
      newvaltoset = pnl.find("div.slider-obj").slider("option", "min");
      hasError = true;
    } else if (thisval > max) {
      newvaltoset = pnl.find("div.slider-obj").slider("option", "max");
      hasError = true;
    }
  }
  pnl.find("div.slider-obj").slider("value", parseFloat(newvaltoset));
  if (val.length > 0 && hasError) {
    pnl.find(".ui-slider-handle").addClass("hothandle");
  } else {
    pnl.find(".ui-slider-handle").removeClass("hothandle");
  }
}
