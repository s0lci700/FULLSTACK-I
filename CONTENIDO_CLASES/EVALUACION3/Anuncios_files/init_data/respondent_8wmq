function FlashMessage(message, messagetype) {
  if (message == null || message.length === 0) return;
  if (messagetype == undefined) messagetype = "Success";
  var icon = "fa-check";

  $(".pnlFlashMessage").remove();
  var panel = $("<div>");
  if (messagetype == "Error") {
    icon = "fa-times";
  } else if (messagetype == "Warning") {
    icon = "fa-warning";
  }

  panel.attr("class", "pnlFlashMessage pnlFlashMessage" + messagetype);
  panel.css("display", "none");

  if (messagetype == "Error") {
    var panelclose = $(
      '<a href="#" title="Close"><i class="fa ' + icon + '"></i></a>',
    );
    $(panelclose).click(function (e) {
      e.preventDefault();
      $(panelclose)
        .closest(".pnlFlashMessage")
        .slideUp("slow", function () {
          $(panelclose).closest(".pnlFlashMessage").remove();
        });
      return false;
    });
    $(panel).attr("role", "alert");
    $(panelclose).appendTo(panel);
    $("<span>" + message + "</span>").appendTo($(panel));

    $(panel).hide().appendTo("body").slideDown();
  } else {
    $(panel).attr("role", "info");
    $('<div><i class="fa ' + icon + '"></i> ' + message + "</div>").appendTo(
      $(panel),
    );
    $(panel).hide().appendTo("body").slideDown();
    $(panel)
      .delay(4000)
      .slideUp("slow", function () {
        panel.remove();
      });
  }
}

