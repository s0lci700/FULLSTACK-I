/**
 * GLOBAL FIX: Prevent unwanted form submission when pressing Enter on checkboxes/radio buttons
 *
 * PROBLEM BEING SOLVED:
 * - Users pressing Enter key on checkboxes/radio buttons would accidentally submit forms
 * - This caused destructive actions (saving incomplete questions) across multiple pages
 * - The issue was widespread affecting 20+ pages including QuestionEdit.aspx, SurveyEdit.aspx, etc.
 * - ASP.NET WebForms default button behavior was triggering form submission on Enter keypress
 *
 * SOLUTION APPROACH:
 * - Intercept Enter key presses globally on all checkbox/radio inputs
 * - Prevent form submission while preserving natural checkbox/radio behavior
 * - Maintain all existing onclick handlers and change events for backward compatibility
 * - Use event delegation to handle dynamically added elements
 *
 * WHY GLOBAL APPROACH:
 * - Issue affects numerous pages across the application
 * - Single point of maintenance instead of scattered page-specific fixes
 * - Automatically protects future pages with checkboxes/radio buttons
 * - More reliable than trying to fix individual ASP.NET default button behaviors
 */
$(document).ready(function () {
  $(document).on(
    "keypress",
    'input[type="checkbox"], input[type="radio"]',
    function (e) {
      if (e.which === 13) {
        e.preventDefault(); // Prevents default browser behavior (form submission)
        e.stopPropagation(); // Stops event from bubbling up to parent elements
        e.stopImmediatePropagation(); // Stops other event handlers on same element from executing

        if (this.type === "checkbox") {
          this.checked = !this.checked; // Toggle checkbox state
        } else if (this.type === "radio") {
          this.checked = true; // Select radio button
        }

        // Execute onclick attribute handlers if present
        if (this.onclick && typeof this.onclick === "function") {
          this.onclick.call(this, e);
        }

        // This ensures ARIA announcements, validation, and other change listeners still work
        $(this).trigger("change");

        // STEP 5: Return false as additional prevention measure
        return false;
      }
    },
  );
});

