function findPosX(obj) {
    var curleft = 0;
    if (obj.offsetParent) {
        while (1) {
            curleft += obj.offsetLeft;
            if (!obj.offsetParent) {
                break;
            }
            obj = obj.offsetParent;
        }
    } else if (obj.x) {
        curleft += obj.x;
    }
    return curleft;
}

function findPosY(obj) {
    var curtop = 0;
    if (obj.offsetParent) {
        while (1) {
            curtop += obj.offsetTop;
            if (!obj.offsetParent) {
                break;
            }
            obj = obj.offsetParent;
        }
    } else if (obj.y) {
        curtop += obj.y;
    }
    return curtop;
}

/**************************************************************************************
// Use the following two functions to prevent ASP.NET RequiredFieldValidator fields
// from validating when the associated field loses focus. In this scenario, the
// validation for required fields should only be done upon saving/submitting the form.
// Call DisableRequiredFieldValidators(false) upon page load and call
// EnableRequiredFieldValidators() upon click of the Save or Submit button.
**************************************************************************************/
function DisableRequiredFieldValidators(flag) {
    if (Page_Validators) {
        for (let i = 0; i < Page_Validators.length; i++) {
            if (Page_Validators[i].evaluationfunction == 'RequiredFieldValidatorEvaluateIsValid' || Page_Validators[i].evaluationfunction?.name == 'RequiredFieldValidatorEvaluateIsValid') {
                Page_Validators[i].enabled = flag;
            }
        }
    }
}

function EnableRequiredFieldValidators() {
    DisableRequiredFieldValidators(true);
    Page_ClientValidate();

    if (!Page_IsValid) {
        DisableRequiredFieldValidators(false);

        // Add classes that indicate an invalid field to the associated label.
        if (Page_Validators) {
            for (let i = 0; i < Page_Validators.length; i++) {
                const valField = Page_Validators[i];
                if (!valField.isvalid) {
                    const ctrlToValidate = document.getElementById(valField.controltovalidate);
                    if (ctrlToValidate) {
                        const labelField = document.querySelector("label[for='" + ctrlToValidate.id + "']")
                        if (labelField) {
                            labelField.classList.add("validationLabel", "validation")
                        }
                    }
                }
            }
        }
    }

    return Page_IsValid;
}

// Check if an ASP.NET validator field is valid or not by running the associated evaulator function.
function IsValidationFieldValid(field) {
    const validator = Page_Validators.find(valField => valField.controltovalidate === field.id);
    return validator && validator.evaluationfunction ? validator.evaluationfunction(validator) : true;
}

function BooleanConvert(strValue) {
    return strValue ? strValue.toLowerCase() === 'true' : false;
}

function appendScript(filepath) {
    if ($('head script[src="' + filepath + '"]').length > 0)
        return;

    var ele = document.createElement('script');
    ele.setAttribute("type", "text/javascript");
    ele.setAttribute("src", filepath);
    $('head').append(ele);
}

function appendStyle(filepath) {
    if ($('head link[href="' + filepath + '"]').length > 0)
        return;

    var ele = document.createElement('link');
    ele.setAttribute("type", "text/css");
    ele.setAttribute("rel", "Stylesheet");
    ele.setAttribute("href", filepath);
    $('head').append(ele);
}

function handleHeaderClick (event) {
    // Find the sortable element (anchor or button) within this th
    const sortableElement = event.currentTarget.querySelector('a, button');

    if (sortableElement) {
        // Check if the click came directly from the sortable element itself, if so, let it through
        if (event.target === sortableElement || sortableElement.contains(event.target)) {
            return;
        }
        // Otherwise, trigger click on the sortable column header element
        sortableElement.focus();
        sortableElement.click();
    }
}

/**
 * Asp.NET does not have a decent way to allow us to click the table heading element itself (th tag) to sort a column
 *
 * We are using this function to redirect any click within the table heading element to the actual element that does
 * the sorting, this enables the requested behavior from Ripple's design team
 */
function initTableHeaderSorting() {
    // Find the table
    const table = document.querySelector('.table.ripple');

    if (!table) return;

    // Get all th elements in the table header
    const headerCells = table.querySelectorAll('th');

    headerCells.forEach(function(th) {
        // Remove existing click handlers to prevent duplicates
        th.removeEventListener('click', handleHeaderClick);

        // Check if this th contains a sortable element (anchor or button)
        const sortableElement = th.querySelector('a, button');

        if (sortableElement) {
            th.addEventListener('click', handleHeaderClick);
        }
    });
}

