function setAllSliderRanges() {
  /* Questions */
  $("div.panel-slider-range").each(function (i) {
    var $this = $(this);
    doRange($this);
    var min = $this.data("min");
    var max = $this.data("max");

    // textbox number mask
    var hasDecimalInterval =
      ($this.data("step") + "").indexOf(".") > -1 ||
      (min + "").indexOf(".") > -1 ||
      (max + "").indexOf(".") > -1;
    $this.find('input[type="text"]').bind("paste", function () {
      var tb = $(this);
      setTimeout(
        jQuery.proxy(function () {
          if (hasDecimalInterval) this.val(tb.val().replace(/[^0-9]/g, ""));
          else this.val(tb.val().replace(/[^0-9\.]/g, ""));
        }, $(this)),
        0,
      );
    });
    $this.find('input[type="text"]').on("keypress blur", function (event) {
      if (hasDecimalInterval) {
        //this.value = this.value.replace(/[^0-9\.]/g,'');
        $(this).val(
          $(this)
            .val()
            .replace(/[^0-9\.]/g, ""),
        );
        if (
          $(this).val().indexOf(".") != -1 &&
          (event.which < 48 || event.which > 57) &&
          event.which != 8 &&
          event.which != 46
        ) {
          event.preventDefault();
        }
      } else {
        $(this).val(
          $(this)
            .val()
            .replace(/[^\d].+/, ""),
        );
        if (
          (event.which < 48 || event.which > 57) &&
          event.which != 8 &&
          event.which != 46
        ) {
          event.preventDefault();
        }
      }
    });

    var start = $this.find(".start");
    var end = $this.find(".end");
    start.bind("keyup change", function () {
      if (end.val().length === 0 && this.value.length > 0) end.val(max);
      setSliderRangeValue($this, this.value, end.val());
    });

    end.bind("keyup change", function () {
      if (start.val().length === 0 && this.value.length > 0) start.val(min);
      setSliderRangeValue($this, start.val(), this.value);
    });
  });
