      if (!isInsideTableScrollXGrid(toggle)) return;
      if (!findScrollClippingAncestor(toggle)) return;

      menu.setAttribute("data-evalkit-fixed-dropdown", "1");
      menu.style.position = "fixed";
      menu.style.zIndex = "1035";
      var entry = {
        toggle: toggle,
        menu: menu,
        isDropup: dropdown.classList.contains("dropup"),
        isRightAligned: menu.classList.contains("dropdown-menu-right"),
      };
      openEntries.push(entry);
      applyMenuCoords(entry);
      ensureGlobalListeners();
    })
    .on("hidden.bs.dropdown", function (e) {
      var dropdown = $(e.target).closest(".dropdown")[0];
      if (!dropdown) return;
      var menu = dropdown.querySelector(".dropdown-menu");
      clearFixed(menu);
      removeGlobalListenersIfIdle();
    });
