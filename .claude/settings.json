{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File .claude/hooks/compile-on-edit.ps1"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File .claude/hooks/notion-after-push.ps1"
          }
        ]
      }
    ]
  }
}
