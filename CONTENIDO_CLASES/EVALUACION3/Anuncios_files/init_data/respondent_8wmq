function GetXmlDoc(val) {
    var xmlDoc;
    try //Internet Explorer
          {
        xmlDoc = new ActiveXObject("Microsoft.XMLDOM");
        xmlDoc.async = "false";
        if (val != null && Trim(val).length > 0)
            xmlDoc.loadXML(val);
    }
    catch (e) {
        try // Firefox, Mozilla, Opera, etc.
            {
            var objDOMParser = new DOMParser();
            if (val != null && Trim(val).length > 0)
                xmlDoc = objDOMParser.parseFromString(val, "text/xml");
            xmlDoc.async = false;
        }
        catch (e) {
            alert(e.message);
            return;
        }
    }

    return xmlDoc;
}

