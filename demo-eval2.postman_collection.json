{
  "info": {
    "name": "Demo — Evaluación Parcial 2",
    "_postman_id": "demo-eval2-dsy1103-2026",
    "description": "Demo guiada para video — DSY1103 DUOC UC (Sol León & Catalina Aguirre).\n9 requests: login → reserva → confirmar → entrada → salida → cobro → 3 errores.\n\nPREPARACIÓN:\n  1. .\\scripts\\load-db.ps1\n  2. .\\scripts\\start-all.ps1\n  3. http://localhost:8761 → todos los servicios en UP\n  4. Limpiar current values de: token, reservaId, accesoId\n\nCorrer de arriba hacia abajo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base",      "value": "http://localhost:8080", "type": "string" },
    { "key": "token",     "value": "",                      "type": "string" },
    { "key": "reservaId", "value": "",                      "type": "string" },
    { "key": "accesoId",  "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "01 — Login",
      "item": [
        {
          "name": "Login admin — captura token JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Token JWT capturado', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.token).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('token', j.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@parking.cl\",\n  \"password\": \"Test1234!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base}}/api/auth/login",
              "host": ["{{base}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "02 — Flujo principal",
      "item": [
        {
          "name": "POST crear reserva  (3 Feign: cliente + vehículo + espacio)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Estado PENDIENTE — 3 validaciones Feign pasadas', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.estado).to.eql('PENDIENTE');",
                  "  pm.expect(j.idEspacio).to.eql(3);",
                  "  pm.collectionVariables.set('reservaId', String(j.id));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idCliente\": 1,\n  \"idVehiculo\": 1,\n  \"idEspacio\": 3,\n  \"fechaInicio\": \"2026-05-22T10:00:00\",\n  \"fechaFin\": \"2026-05-22T12:00:00\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base}}/api/reservas",
              "host": ["{{base}}"],
              "path": ["api", "reservas"]
            }
          }
        },
        {
          "name": "PUT confirmar reserva  (PENDIENTE → CONFIRMADA)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Estado CONFIRMADA', () => {",
                  "  pm.expect(pm.response.json().estado).to.eql('CONFIRMADA');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{base}}/api/reservas/{{reservaId}}/confirmar",
              "host": ["{{base}}"],
              "path": ["api", "reservas", "{{reservaId}}", "confirmar"]
            }
          }
        },
        {
          "name": "POST registrar entrada  (espacio → no disponible vía Feign)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Acceso ACTIVO — espacio marcado ocupado', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.estado).to.eql('ACTIVO');",
                  "  pm.expect(j.fechaHoraSalida).to.be.null;",
                  "  pm.collectionVariables.set('accesoId', String(j.id));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idReserva\": {{reservaId}},\n  \"idVehiculo\": 1,\n  \"patenteEscaneada\": \"BBBB11\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base}}/api/accesos/entrada",
              "host": ["{{base}}"],
              "path": ["api", "accesos", "entrada"]
            }
          }
        },
        {
          "name": "PUT registrar salida  (minutos calculados, espacio liberado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Estado COMPLETADO — minutos calculados', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.estado).to.eql('COMPLETADO');",
                  "  pm.expect(j.fechaHoraSalida).to.not.be.null;",
                  "  pm.expect(j.minutos).to.be.a('number').and.to.be.at.least(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{base}}/api/accesos/{{accesoId}}/salida",
              "host": ["{{base}}"],
              "path": ["api", "accesos", "{{accesoId}}", "salida"]
            }
          }
        },
        {
          "name": "POST crear cobro  (7 Feign + fórmula BigDecimal)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('montoBase y montoFinal calculados con BigDecimal', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.montoBase).to.be.a('number');",
                  "  pm.expect(j.montoFinal).to.be.a('number').and.to.be.at.least(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idAcceso\": {{accesoId}},\n  \"idMetodoPago\": 1,\n  \"idCliente\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base}}/api/cobros",
              "host": ["{{base}}"],
              "path": ["api", "cobros"]
            }
          }
        }
      ]
    },
    {
      "name": "03 — Errores (GlobalExceptionHandler)",
      "item": [
        {
          "name": "POST reserva sin campos → 400  (Bean Validation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('VALIDATION_FAILED con mapa de campos', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.error).to.eql('VALIDATION_FAILED');",
                  "  pm.expect(j.campos).to.be.an('object');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idCliente\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base}}/api/reservas",
              "host": ["{{base}}"],
              "path": ["api", "reservas"]
            }
          }
        },
        {
          "name": "GET cliente 999 → 404  (NotFoundException)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('404 Not Found', () => pm.response.to.have.status(404));",
                  "pm.test('GlobalExceptionHandler → NOT_FOUND', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.error).to.eql('NOT_FOUND');",
                  "  pm.expect(j).to.have.property('mensaje');",
                  "  pm.expect(j).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base}}/api/clientes/999",
              "host": ["{{base}}"],
              "path": ["api", "clientes", "999"]
            }
          }
        },
        {
          "name": "POST cobro duplicado → 422  (BusinessException — UNIQUE id_acceso_ref)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('422 Unprocessable Entity', () => pm.response.to.have.status(422));",
                  "pm.test('GlobalExceptionHandler → BUSINESS_RULE_VIOLATION', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.error).to.eql('BUSINESS_RULE_VIOLATION');",
                  "  pm.expect(j).to.have.property('mensaje');",
                  "  pm.expect(j).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idAcceso\": {{accesoId}},\n  \"idMetodoPago\": 1,\n  \"idCliente\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base}}/api/cobros",
              "host": ["{{base}}"],
              "path": ["api", "cobros"]
            }
          }
        }
      ]
    }
  ]
}
