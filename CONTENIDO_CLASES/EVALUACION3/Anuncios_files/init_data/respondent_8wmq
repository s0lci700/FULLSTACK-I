      if (
        ox === "auto" ||
        ox === "scroll" ||
        ox === "hidden" ||
        oy === "auto" ||
        oy === "scroll" ||
        oy === "hidden"
      ) {
        return node;
      }
    }
    return null;
  }

  function applyMenuCoords(entry) {
    var tr = entry.toggle.getBoundingClientRect();
    var menu = entry.menu;
    if (entry.isDropup) {
      menu.style.top = tr.top - (menu.offsetHeight || 0) + "px";
    } else {
      menu.style.top = tr.bottom + "px";
    }
    menu.style.bottom = "auto";
    if (entry.isRightAligned) {
      menu.style.left = "auto";
      menu.style.right = document.documentElement.clientWidth - tr.right + "px";
