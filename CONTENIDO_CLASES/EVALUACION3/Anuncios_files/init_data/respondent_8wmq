          (event.which < 48 || event.which > 57) &&
          event.which != 8 &&
          event.which != 46
        ) {
          event.preventDefault();
        }
      }
    });

    $this.find('input[type="text"]').bind("keyup change", function () {
      setSliderValue($this, this.value);
    });
  });

  setAllSliderRanges();
