function cesBindScheduleDaysDigitsOnly(selector, max) {
    $(selector).off('input.scheduleDaysDigits').on('input.scheduleDaysDigits', function () {
        var raw = this.value.replace(/\D/g, '');
        if (raw === '') {
            if (this.value !== '') this.value = '';
            return;
        }
        var n = parseInt(raw, 10);
        if (isNaN(n)) return;
        if (n > max) n = max;
        var next = String(n);
        if (this.value !== next) this.value = next;
    });
}

/** emptyAsZero on blur: blank / 0 placeholder stays 0; omit on save to treat blank as min. */
function cesEnforceWholeDaysInRange(input, min, max, emptyAsZero) {
    if (!input) return;
    var idleBlur = emptyAsZero === true;
    var $el = $(input);
    var raw = $.trim($el.val());
    if (raw === '') {
        $el.val(idleBlur ? '0' : String(min));
        return;
    }
    var digits = raw.replace(/\D/g, '');
    if (digits === '') {
        $el.val(idleBlur ? '0' : String(min));
        return;
    }
    var n = parseInt(digits, 10);
    if (isNaN(n)) {
        $el.val(idleBlur ? '0' : String(min));
        return;
    }
    if (idleBlur && min >= 1 && n === 0) {
        $el.val('0');
        return;
    }
    if (n < min) n = min;
    if (n > max) n = max;
    $el.val(String(n));
}
