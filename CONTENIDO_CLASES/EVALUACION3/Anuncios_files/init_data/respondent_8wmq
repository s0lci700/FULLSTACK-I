function doSlider(pnl) {
  var inputVal = pnl.find('input[type="text"]');
  var divSlider = pnl.find("div.slider-obj");

  const minValue = parseFloat(pnl.data("min"));
  const maxValue = parseFloat(pnl.data("max"));
  divSlider.slider({
    min: minValue,
